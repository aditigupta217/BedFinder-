# BedFinder Environment Variables

# Gemini API Key for the AI Triage Assistant
# Get a key from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) EmailJS configuration keys if you want to set up custom email notifications
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=
